# SIFIX Extension Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API Key (for AI-powered transaction analysis)
# Get it from: https://platform.openai.com/api-keys
PLASMO_PUBLIC_OPENAI_API_KEY=sk-...

# 0G Chain RPC URL (for transaction simulation)
# Testnet: https://evmrpc-testnet.0g.ai
# Mainnet: https://evmrpc.0g.ai
PLASMO_PUBLIC_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage URL (for threat intelligence data)
# Get it from: https://docs.0g.ai/storage
PLASMO_PUBLIC_ZEROG_STORAGE_URL=https://storage-testnet.0g.ai

# 0G Compute URL (optional, for decentralized AI inference)
# Get it from: https://docs.0g.ai/compute
PLASMO_PUBLIC_ZEROG_COMPUTE_URL=https://compute-testnet.0g.ai

# SIFIX Reputation Contract Address (deployed on 0G Chain)
# Will be provided after deployment
PLASMO_PUBLIC_CONTRACT_ADDRESS=0x...
