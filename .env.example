# SIFIX Extension Environment Variables
# Copy this file to ..env and fill in your config

# ============================================
# dApp Connection (REQUIRED)
# ============================================
# SIFIX dApp API URL - all AI/scan/analysis goes through this
# Local dev: http://localhost:3001/api/v1
# Production: https://your-sifix-dapp.vercel.app/api/v1
PLASMO_PUBLIC_DAPP_API_URL=http://localhost:3001/api/v1

# ============================================
# Network (REQUIRED)
# ============================================
# 0G Chain RPC URL (for transaction simulation)
PLASMO_PUBLIC_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Chain ID
PLASMO_PUBLIC_CHAIN_ID=16602

# ============================================
# Contract (REQUIRED)
# ============================================
# SIFIX Reputation Contract Address (deployed on 0G Chain)
PLASMO_PUBLIC_CONTRACT_ADDRESS=0x544a39149d5169E4e1bDf7F8492804224CB70152

# ============================================
# NOTE: AI Provider is NOT configured here!
# ============================================
# AI config (OpenAI, Groq, 0G Compute, Ollama) is managed
# in the dApp dashboard at /dashboard/settings
#
# Flow:
#   Extension -> dApp API -> AI Provider (user's choice)
#   User connects wallet -> configures AI in dApp dashboard
#
# Options available in dApp:
#   - 0G Compute (decentralized, pay with 0G tokens)
#   - OpenAI (bring your own API key)
#   - Groq (bring your own API key)
#   - Ollama (local, free)
#   - Custom endpoint
