    "sharp": "^0.34.5",
    "tailwind-merge": "^2.2.0",
    "viem": "^2.9.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "@types/chrome": "0.0.268",
    "@types/node": "20.11.24",
